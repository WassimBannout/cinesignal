# --- CineSignal ---
# Raw data is NEVER committed (PRD §12.0). It is sourced per docs/decisions.md.
data/raw/
# Processed artifacts are generated by the pipeline. Per OQ5 (resolved) we commit the
# small demo Parquet for deploy/CI reliability; the pipeline still regenerates it.
# NB: ignore the *contents* (/*) not the dir itself, so the negation below can re-include.
data/processed/*
!data/processed/movies_clean.parquet
reports/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

